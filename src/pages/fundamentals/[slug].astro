---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const items = await getCollection('fundamentals');
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<BaseLayout title={item.data.title} description={item.data.summary}>
  <Header />
  <article class="mx-auto max-w-content px-6 py-16 lg:px-8 lg:py-20">
    <a href="/fundamentals" class="text-[13.5px] font-medium text-ink-faint hover:text-accent">&larr; Fundamentals</a>
    <h1 class="mt-5 max-w-2xl text-4xl font-semibold tracking-tight text-ink lg:text-5xl">{item.data.title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-soft">{item.data.summary}</p>
    <div class="prose prose-neutral mt-12 max-w-none">
      <Content />
    </div>
  </article>
  <Footer />
</BaseLayout>
