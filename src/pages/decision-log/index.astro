---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ADRCard from '../../components/ADRCard.astro';

const items = (await getCollection('decisions')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Decision Log" description="Architecture-decision-record style log of the authentication decisions behind LoginOS's recommendations.">
  <Header />
  <section class="mx-auto max-w-content px-6 py-16 lg:px-8 lg:py-20">
    <SectionHeader
      eyebrow="ADR-style records"
      title="Decision Log"
      description="Every recommendation in this playbook traces back to a documented decision — context, options considered, and rationale included."
    />
    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {items.map((item) => (
        <ADRCard
          id={item.data.id}
          title={item.data.title}
          status={item.data.status}
          recommendation={item.data.recommendation}
          href={`/decision-log/${item.slug}`}
        />
      ))}
    </div>
  </section>
  <Footer />
</BaseLayout>
