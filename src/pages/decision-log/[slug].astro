---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const items = await getCollection('decisions');
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const statusStyles: Record<string, string> = {
  Proposed: 'bg-paper-soft text-ink-soft border-line',
  Accepted: 'bg-accent-light text-accent-dark border-accent/20',
  Rejected: 'bg-paper-soft text-ink-faint border-line',
  Superseded: 'bg-paper-soft text-ink-faint border-line',
};
---

<BaseLayout title={`${item.data.id} — ${item.data.title}`} description={item.data.recommendation}>
  <Header />
  <article class="mx-auto max-w-content px-6 py-16 lg:px-8 lg:py-20">
    <a href="/decision-log" class="text-[13.5px] font-medium text-ink-faint hover:text-accent">&larr; Decision Log</a>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <span class="font-mono text-[13px] font-medium text-accent">{item.data.id}</span>
      <span class:list={['rounded-full border px-2.5 py-1 font-mono text-[10.5px] uppercase tracking-wide', statusStyles[item.data.status]]}>
        {item.data.status}
      </span>
    </div>
    <h1 class="mt-3 max-w-2xl text-4xl font-semibold tracking-tight text-ink lg:text-5xl">{item.data.title}</h1>

    <div class="mt-8 max-w-2xl rounded-2xl border border-accent/25 bg-accent-faint p-6">
      <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-accent">Recommendation</p>
      <p class="mt-2 text-lg leading-relaxed text-ink">{item.data.recommendation}</p>
    </div>

    <div class="mt-12 grid max-w-2xl gap-10">
      <div>
        <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-ink-faint">Context</h2>
        <p class="mt-3 text-[15.5px] leading-relaxed text-ink-soft">{item.data.context}</p>
      </div>

      <div>
        <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-ink-faint">Options considered</h2>
        <ul class="mt-4 flex flex-col gap-4">
          {item.data.options.map((opt) => (
            <li class="rounded-xl border border-line p-4">
              <p class="font-medium text-ink">{opt.name}</p>
              <p class="mt-1.5 text-[14.5px] leading-relaxed text-ink-soft">{opt.description}</p>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-ink-faint">Rationale</h2>
        <p class="mt-3 text-[15.5px] leading-relaxed text-ink-soft">{item.data.rationale}</p>
      </div>

      <div>
        <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-ink-faint">Risks</h2>
        <ul class="mt-3 flex flex-col gap-2">
          {item.data.risks.map((risk) => (
            <li class="flex items-start gap-2.5 text-[14.5px] leading-relaxed text-ink-soft">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ink-faint"></span>
              {risk}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </article>
  <Footer />
</BaseLayout>
