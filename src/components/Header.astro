---
const nav = [
  { label: 'Fundamentals', href: '/fundamentals' },
  { label: 'Patterns', href: '/patterns' },
  { label: 'Benchmarks', href: '/benchmarks' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Decision Log', href: '/decision-log' },
  { label: 'Roadmap', href: '/roadmap' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/90 backdrop-blur">
  <div class="mx-auto flex max-w-content items-center justify-between px-6 py-4 lg:px-8">
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <span class="h-3 w-3 rounded-[3px] bg-accent"></span>
      <span class="font-mono text-[15px] font-medium tracking-tight text-ink">LoginOS</span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-[14.5px] font-medium transition-colors hover:text-ink',
            isActive(item.href) ? 'text-ink' : 'text-ink-soft',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      id="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      class="flex h-9 w-9 flex-col items-center justify-center gap-[5px] rounded-md border border-line lg:hidden"
    >
      <span class="block h-[1.5px] w-4 bg-ink transition-transform" id="bar-1"></span>
      <span class="block h-[1.5px] w-4 bg-ink transition-opacity" id="bar-2"></span>
      <span class="block h-[1.5px] w-4 bg-ink transition-transform" id="bar-3"></span>
    </button>
  </div>

  <nav
    id="mobile-nav"
    class="hidden flex-col border-t border-line bg-paper px-6 py-4 lg:hidden"
  >
    {nav.map((item) => (
      <a
        href={item.href}
        class:list={[
          'border-b border-line py-3 text-[15px] font-medium last:border-none',
          isActive(item.href) ? 'text-ink' : 'text-ink-soft',
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  const bar1 = document.getElementById('bar-1');
  const bar2 = document.getElementById('bar-2');
  const bar3 = document.getElementById('bar-3');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('flex');
    menu?.classList.toggle('flex', !isOpen);
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    bar1?.style.setProperty('transform', isOpen ? 'none' : 'translateY(6.5px) rotate(45deg)');
    bar3?.style.setProperty('transform', isOpen ? 'none' : 'translateY(-6.5px) rotate(-45deg)');
    if (bar2) bar2.style.opacity = isOpen ? '1' : '0';
  });
</script>
