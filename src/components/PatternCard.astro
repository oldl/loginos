---
export interface Props {
  title: string;
  href: string;
  tags: string[];
  problem: string;
  recommendation: string;
  uxImpact: string;
  securityImpact: string;
  implementationNotes: string;
  index: number;
}
const { title, href, tags, problem, recommendation, uxImpact, securityImpact, implementationNotes, index } = Astro.props;
---

<article class="rounded-2xl border border-line bg-white/60 p-7 lg:p-8">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <span class="font-mono text-[12px] text-ink-faint">{String(index).padStart(2, '0')}</span>
      <h3 class="text-xl font-semibold tracking-tight text-ink">
        <a href={href} class="hover:text-accent">{title}</a>
      </h3>
    </div>
    <div class="flex flex-wrap gap-2">
      {tags.map((t) => (
        <span class="rounded-full border border-line bg-paper-soft px-2.5 py-1 font-mono text-[10.5px] uppercase tracking-wide text-ink-soft">{t}</span>
      ))}
    </div>
  </div>

  <dl class="mt-6 grid gap-5 sm:grid-cols-2">
    <div>
      <dt class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-faint">Problem</dt>
      <dd class="mt-1.5 text-[14.5px] leading-relaxed text-ink-soft">{problem}</dd>
    </div>
    <div>
      <dt class="font-mono text-[11px] uppercase tracking-[0.12em] text-accent">Recommendation</dt>
      <dd class="mt-1.5 text-[14.5px] leading-relaxed text-ink">{recommendation}</dd>
    </div>
    <div>
      <dt class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-faint">UX impact</dt>
      <dd class="mt-1.5 text-[14.5px] leading-relaxed text-ink-soft">{uxImpact}</dd>
    </div>
    <div>
      <dt class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-faint">Security impact</dt>
      <dd class="mt-1.5 text-[14.5px] leading-relaxed text-ink-soft">{securityImpact}</dd>
    </div>
  </dl>

  <div class="mt-5 border-t border-line pt-5">
    <dt class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-faint">Implementation notes</dt>
    <dd class="mt-1.5 text-[14.5px] leading-relaxed text-ink-soft">{implementationNotes}</dd>
  </div>
</article>
