---
const columns = [
  {
    heading: 'Playbook',
    links: [
      { label: 'Fundamentals', href: '/fundamentals' },
      { label: 'Patterns', href: '/patterns' },
      { label: 'Roadmap', href: '/roadmap' },
    ],
  },
  {
    heading: 'Evidence',
    links: [
      { label: 'Benchmarks', href: '/benchmarks' },
      { label: 'Case Studies', href: '/case-studies' },
      { label: 'Decision Log', href: '/decision-log' },
    ],
  },
];
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-content px-6 py-14 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.3fr_1fr_1fr]">
      <div>
        <a href="/" class="flex items-center gap-2.5">
          <span class="h-3 w-3 rounded-[3px] bg-accent"></span>
          <span class="font-mono text-[15px] font-medium tracking-tight text-ink">LoginOS</span>
        </a>
        <p class="mt-4 max-w-xs text-[14.5px] leading-relaxed text-ink-soft">
          Where authentication becomes product strategy.
        </p>
      </div>
      {columns.map((col) => (
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-ink-faint">{col.heading}</p>
          <ul class="mt-4 flex flex-col gap-3">
            {col.links.map((l) => (
              <li><a href={l.href} class="text-[14.5px] text-ink-soft hover:text-ink">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-14 flex flex-col gap-2 border-t border-line pt-6 text-[13px] text-ink-faint sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {new Date().getFullYear()} LoginOS. An editorial authentication playbook.</p>
      <p>Built with Astro &middot; Content managed via Decap CMS</p>
    </div>
  </div>
</footer>
