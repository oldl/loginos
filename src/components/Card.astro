---
export interface Props {
  title: string;
  description?: string;
  href?: string;
  index?: number;
}
const { title, description, href, index } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group flex flex-col justify-between rounded-2xl border border-line bg-white/60 p-6 transition-colors',
    href && 'hover:border-accent/40 hover:bg-white',
  ]}
>
  <div>
    {typeof index === 'number' && (
      <span class="font-mono text-[12px] text-ink-faint">{String(index).padStart(2, '0')}</span>
    )}
    <h3 class="mt-3 text-lg font-semibold tracking-tight text-ink">{title}</h3>
    {description && <p class="mt-2.5 text-[14.5px] leading-relaxed text-ink-soft">{description}</p>}
  </div>
  {href && (
    <span class="mt-6 inline-flex items-center gap-1.5 text-[13.5px] font-medium text-accent">
      Read more
      <span class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
    </span>
  )}
</Tag>
