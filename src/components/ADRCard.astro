---
export interface Props {
  id: string;
  title: string;
  status: 'Proposed' | 'Accepted' | 'Rejected' | 'Superseded';
  recommendation: string;
  href: string;
}
const { id, title, status, recommendation, href } = Astro.props;
const statusStyles: Record<string, string> = {
  Proposed: 'bg-paper-soft text-ink-soft border-line',
  Accepted: 'bg-accent-light text-accent-dark border-accent/20',
  Rejected: 'bg-paper-soft text-ink-faint border-line',
  Superseded: 'bg-paper-soft text-ink-faint border-line',
};
---

<article class="rounded-2xl border border-line bg-white/60 p-7">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <span class="font-mono text-[12.5px] font-medium text-accent">{id}</span>
    <span class:list={['rounded-full border px-2.5 py-1 font-mono text-[10.5px] uppercase tracking-wide', statusStyles[status]]}>
      {status}
    </span>
  </div>
  <h3 class="mt-3 text-xl font-semibold tracking-tight text-ink">
    <a href={href} class="hover:text-accent">{title}</a>
  </h3>
  <p class="mt-3 text-[14.5px] leading-relaxed text-ink-soft">
    <span class="font-medium text-ink">Recommendation &mdash;</span> {recommendation}
  </p>
  <a href={href} class="mt-5 inline-flex items-center gap-1.5 text-[13.5px] font-medium text-accent">
    Read the full decision <span>&rarr;</span>
  </a>
</article>
